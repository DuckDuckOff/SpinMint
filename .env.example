# ─── Coinbase / OnchainKit ─────────────────────────────────────────────────────
# Get from: https://portal.cdp.coinbase.com
NEXT_PUBLIC_CDP_CLIENT_API_KEY=your_cdp_api_key_here

# ─── Your deployed contract ────────────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ─── App URL (your Vercel URL) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://spinmint.vercel.app

# ─── Farcaster manifest (generated by: npx create-onchain --mini) ──────────────
# Sign with your Farcaster custody wallet at: warpcast.com/~/developers/mini-apps/manifest
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# ─── Backend (for granting free spins) ────────────────────────────────────────
# Your deployer/owner wallet private key (KEEP SECRET — never commit this)
OWNER_PRIVATE_KEY=0xYOUR_OWNER_WALLET_PRIVATE_KEY

# Base RPC (free from Alchemy or QuickNode)
BASE_RPC_URL=https://mainnet.base.org

# Neynar API key (optional — for verifying casts before granting free spins)
# Get from: https://neynar.com
NEYNAR_API_KEY=your_neynar_key_here
